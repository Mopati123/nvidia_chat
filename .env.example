# ApexQuantumICT Trading System - Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# =============================================================================
# NVIDIA AI API (Required for Telegram bot AI features)
# =============================================================================
NVAPI_KEY=nvapi-your-key-here

# =============================================================================
# Telegram Bot (Required for Telegram integration)
# =============================================================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# =============================================================================
# Broker Configuration
# =============================================================================
# Master password for credential encryption (if not using keyring)
# APEX_CREDENTIAL_PASSWORD=your-secure-master-password

# Deriv.com settings
DERIV_ENABLED=true
DERIV_DEFAULT_ACCOUNT=demo

# MetaTrader 5 settings
MT5_ENABLED=true
MT5_DEFAULT_ACCOUNT=default
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# =============================================================================
# Data & Logging Paths
# =============================================================================
BROKER_DATA_CACHE_PATH=./data/broker_cache
BROKER_LOG_PATH=./logs/brokers
MARKET_DATA_CACHE_PATH=./data/market_cache

# =============================================================================
# Trading Settings
# =============================================================================
DEFAULT_MODE=shadow
RISK_PER_TRADE_PCT=2.0
MAX_POSITIONS=3
ENABLE_NOTIFICATIONS=true

# =============================================================================
# Security Settings
# =============================================================================
# Set to true to require explicit confirmation for live trades
SAFE_MODE=true
# Audit log level: DEBUG, INFO, WARNING, ERROR
AUDIT_LOG_LEVEL=INFO
